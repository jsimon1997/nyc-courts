# Google Cloud API Keys
# IMPORTANT: Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to git (it's in .gitignore)

# Google Places API - for business info (phone, hours, website, reviews)
GOOGLE_PLACES_API_KEY=AIzaSy_YOUR_PLACES_API_KEY_HERE

# Google Custom Search API - for booking URLs and web search results
GOOGLE_SEARCH_API_KEY=AIzaSy_YOUR_SEARCH_API_KEY_HERE

# Optional: Search Engine ID (if using Custom Search)
# Get from: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
